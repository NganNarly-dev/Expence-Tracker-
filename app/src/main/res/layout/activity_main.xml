<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@drawable/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">
    <View
        android:id="@+id/view_1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/view1"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"/>

    <TextView
        android:id="@+id/text_sign_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign In"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/view_1" />
    <TextView
        android:id="@+id/text_sign_in_my_account"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign in my account"
        android:textSize="16sp"
        android:textStyle="normal"
        android:textColor="@color/grey"
        android:layout_marginTop="36dp"
        app:layout_constraintEnd_toEndOf="@+id/text_sign_in"
        app:layout_constraintStart_toStartOf="@+id/text_sign_in"
        app:layout_constraintTop_toTopOf="@+id/text_sign_in" />
    <TextView
        android:id="@+id/text_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Email"
        android:textSize="18sp"
        android:textStyle="normal"
        android:textColor="@color/grey"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="@+id/edit_text_mail"
        app:layout_constraintTop_toBottomOf="@+id/text_sign_in_my_account" />
    <View
        android:id="@+id/ic_mail"
        android:background="@drawable/ic_email"
        app:layout_constraintTop_toTopOf="@+id/edit_text_mail"
        app:layout_constraintStart_toStartOf="@+id/edit_text_mail"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp"
        android:layout_width="28dp"
        android:layout_height="28dp"/>
    <EditText
        android:id="@+id/edit_text_mail"
        android:background="@drawable/bg_khung_nhap"
        app:backgroundTint="@null"
        android:hint="Email"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingStart="40dp"
        android:inputType="textEmailAddress"
        android:textSize="20sp"
        android:textStyle="normal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/ic_mail"
        app:layout_constraintTop_toBottomOf="@+id/text_email"
        android:layout_width="match_parent"
        android:layout_height="48dp"/>
    <TextView
        android:id="@+id/text_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Password"
        android:textSize="18sp"
        android:textStyle="normal"
        android:textColor="@color/grey"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="@+id/edit_text_mail"
        app:layout_constraintTop_toBottomOf="@+id/edit_text_mail" />
    <View
        android:id="@+id/ic_pass"
        android:background="@drawable/ic_password"
        app:layout_constraintTop_toTopOf="@+id/edit_text_password"
        app:layout_constraintStart_toStartOf="@+id/edit_text_password"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp"
        android:layout_width="28dp"
        android:layout_height="28dp"/>
    <EditText
        android:id="@+id/edit_text_password"
        android:background="@drawable/bg_khung_nhap"
        app:backgroundTint="@null"
        android:hint="Password"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingStart="40dp"
        android:textSize="20sp"
        android:textStyle="normal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/ic_pass"
        app:layout_constraintTop_toBottomOf="@+id/text_password"
        android:layout_width="match_parent"
        android:layout_height="48dp"/>
    <View
        android:id="@+id/ic_off_eye_password"
        android:background="@drawable/ic_off_eye"
        app:layout_constraintTop_toTopOf="@+id/edit_text_password"
        app:layout_constraintEnd_toEndOf="@id/edit_text_password"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp"
        android:visibility="gone"
        android:layout_width="28dp"
        android:layout_height="28dp"/>
    <View
        android:id="@+id/ic_op_eye_password"
        android:background="@drawable/ic_op_eye"
        app:layout_constraintTop_toTopOf="@+id/edit_text_password"
        app:layout_constraintEnd_toEndOf="@id/edit_text_password"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp"
        android:visibility="gone"
        android:layout_width="28dp"
        android:layout_height="28dp"/>
    <TextView
        android:id="@+id/text_forgot_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot password?"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:textColor="#9B8AFB"
        app:layout_constraintTop_toBottomOf="@+id/edit_text_password"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"/>
    <Button
        android:id="@+id/button_sign_in"
        app:layout_constraintTop_toBottomOf="@+id/text_forgot_password"
        android:layout_marginTop="12dp"
        android:text="Sign In"
        android:textSize="20sp"
        android:background="@drawable/bg_button"
        app:backgroundTint="@null"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <View
        android:id="@+id/view_2"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="8dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@+id/button_sign_in"
        app:layout_constraintEnd_toStartOf="@+id/text_or"
        android:background="@color/grey"
        android:layout_width="155dp"
        android:layout_height="1dp"/>
    <TextView
        android:id="@+id/text_or"
        app:layout_constraintTop_toBottomOf="@+id/button_sign_in"
        app:layout_constraintStart_toStartOf="@id/view_2"
        app:layout_constraintEnd_toEndOf="@id/view_2"
        android:text="OR"
        android:layout_marginTop="16dp"
        android:textColor="@color/grey"
        android:layout_width="20dp"
        android:layout_height="20dp"/>
    <View
        android:id="@+id/view_3"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="16dp"
        android:layout_marginStart="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button_sign_in"
        app:layout_constraintStart_toEndOf="@+id/text_or"
        android:background="@color/grey"
        android:layout_width="155dp"
        android:layout_height="1dp"/>
    <Button
        android:id="@+id/bt_sign_in_google"
        app:layout_constraintTop_toBottomOf="@+id/text_or"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="match_parent"
        android:layout_marginEnd="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="Sign In with google"
        android:textColor="@color/black"
        android:textSize="20sp"
        app:backgroundTint="@null"
        android:background="@drawable/bg_bt_google"
        android:layout_height="48dp"/>
    <View
        android:id="@+id/ic_google"
        app:layout_constraintTop_toTopOf="@+id/bt_sign_in_google"
        app:layout_constraintStart_toStartOf="@+id/bt_sign_in_google"
        android:background="@drawable/ic_google"
        android:layout_marginStart="8dp"
        android:layout_marginTop="10dp"
        android:layout_width="28dp"
        android:layout_height="28dp"/>
    <TextView
        android:id="@+id/text_sign_up"
        android:text="Don't have an account?"
        android:textSize="16sp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="36dp"
        app:layout_constraintEnd_toEndOf="@+id/bt_sign_in_google"
        app:layout_constraintTop_toBottomOf="@+id/bt_sign_in_google"
        app:layout_constraintStart_toStartOf="@+id/bt_sign_in_google"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/sign_up"
        android:text="Sign Up"
        android:textSize="16sp"
        android:textColor="#9B8AFB"
        android:layout_marginTop="24dp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="52dp"
        app:layout_constraintEnd_toEndOf="@+id/bt_sign_in_google"
        app:layout_constraintTop_toBottomOf="@+id/bt_sign_in_google"
        app:layout_constraintStart_toEndOf="@+id/text_sign_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</androidx.constraintlayout.widget.ConstraintLayout>